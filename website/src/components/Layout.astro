---
import '@/styles/global.css';
import { SITE } from '@/config/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { ui } from '@/i18n/ui';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '/' } = Astro.props;
const canonical = new URL(path, SITE.url).toString();

const lang = getLangFromUrl(new URL(Astro.request.url));
const t = useTranslations(lang);

const homePath = lang === 'en' ? '/' : `/${lang}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/product-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={`${SITE.url}/product-icon.png`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="max-w-6xl mx-auto px-5">
      <div class="flex flex-col lg:flex-row justify-between items-center my-5 gap-3">
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a href={homePath} class="inline-flex items-center gap-2 text-lg">
            <img src="/product-icon.png" alt="DbPaw logo" class="w-6 h-6 rounded-sm" />
            <span class="font-bold text-slate-800">Db</span><span class="text-slate-500">Paw</span>
          </a>
        </div>

        <nav class="w-full lg:w-auto" aria-label="Primary">
          <ul class="flex flex-wrap items-center justify-start lg:justify-center gap-x-1 gap-y-2 text-slate-600">
            <li><a class="flex lg:px-3 py-2 items-center hover:text-slate-900 transition-colors" href="#features">{t('nav.features')}</a></li>
            <li><a class="flex lg:px-3 py-2 items-center hover:text-slate-900 transition-colors" href="#screenshots">{t('nav.preview')}</a></li>
            <li><a class="flex lg:px-3 py-2 items-center hover:text-slate-900 transition-colors" href="#download">{t('nav.download')}</a></li>
            <li><a class="flex lg:px-3 py-2 items-center hover:text-slate-900 transition-colors" href="#faq">{t('nav.faq')}</a></li>
          </ul>
        </nav>

        <div class="w-full lg:w-auto flex items-center gap-3">
          <a
            href={SITE.repo}
            target="_blank"
            rel="noreferrer"
            class="hidden md:block w-full lg:w-auto text-center rounded-sm px-4 py-2 text-slate-600 hover:text-black transition"
          >
            {t('nav.github')}
          </a>
          <div class="flex items-center gap-2 text-sm text-slate-500">
             {lang === 'zh' ? (
                <a href="/" class="hover:text-black">EN</a>
             ) : (
                <span class="font-bold text-black">EN</span>
             )}
             <span>/</span>
             {lang === 'en' ? (
                <a href="/zh" class="hover:text-black">中文</a>
             ) : (
                <span class="font-bold text-black">中文</span>
             )}
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-5">
      <slot />
    </main>

    <footer class="my-20 max-w-6xl mx-auto px-5">
      <p class="text-center text-sm text-slate-500">
        {t('footer.copyright').replace('{year}', new Date().getFullYear().toString())}
      </p>
      <p class="text-center text-xs text-slate-500 mt-1">
        {t('footer.source')}
        <a href={SITE.repo} target="_blank" rel="noreferrer" class="hover:underline">GitHub</a>
      </p>
    </footer>
  </body>
</html>
