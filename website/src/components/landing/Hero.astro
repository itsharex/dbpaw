---
import type { PlatformDownloads } from '@/lib/github';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

interface Props {
  version: string;
  releasedDate: string;
  releaseNotesUrl: string;
  source: 'github' | 'fallback';
  downloads: PlatformDownloads;
}

const { version, releasedDate, releaseNotesUrl, source, downloads } = Astro.props;
const lang = getLangFromUrl(new URL(Astro.request.url));
const t = useTranslations(lang);
---

<section class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <img
      src="/screenshots/app-overview.png"
      alt="DbPaw main workspace preview"
      loading="eager"
      decoding="async"
      class="rounded-xl border border-slate-200"
    />
  </div>
  <div>
    <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      {t('hero.title')}
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      {t('hero.subtitle')}
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <a
        class="rounded-sm px-5 py-2.5 bg-black text-white hover:bg-slate-800 border-2 border-transparent transition text-center"
        id="smart-download"
        href={downloads.mac ?? releaseNotesUrl}
      >
        {t('hero.download')}
      </a>
      <a
        class="rounded-sm px-5 py-2.5 bg-white border-2 border-black hover:bg-gray-100 text-black transition text-center"
        href={releaseNotesUrl}
        target="_blank"
        rel="noreferrer"
      >
        {t('hero.releaseNotes')}
      </a>
    </div>
    <p class="mt-4 text-sm text-slate-500">
      {t('hero.latestRelease')} <strong>{version}</strong>, {t('hero.published')} {releasedDate} ({source === 'github'
        ? t('hero.liveFromGithub')
        : t('hero.fallbackMode')}).
    </p>
  </div>
</section>

<script is:inline define:vars={{ links: downloads, fallback: releaseNotesUrl, texts: { mac: t('hero.downloadMac'), win: t('hero.downloadWin'), linux: t('hero.downloadLinux') } }}>
  const downloadButton = document.getElementById('smart-download');
  if (downloadButton) {
    const userAgent = navigator.userAgent.toLowerCase();
    let platform = 'mac';
    if (userAgent.includes('win')) platform = 'windows';
    else if (userAgent.includes('linux')) platform = 'linux';

    const target = links[platform] ?? fallback;
    downloadButton.href = target;
    downloadButton.textContent =
      platform === 'mac'
        ? texts.mac
        : platform === 'windows'
          ? texts.win
          : texts.linux;
  }
</script>
