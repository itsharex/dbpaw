---
import { FAQS } from '@/config/faqs';
---

<section id="faq" class="section">
  <div class="section-head">
    <p class="kicker">FAQ</p>
    <h2>Common questions before your first install</h2>
  </div>
  <div class="faq-grid">
    {
      FAQS.map((item) => (
        <article class="faq-card">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))
    }
  </div>
</section>
