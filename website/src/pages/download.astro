---
import Layout from '@/components/Layout.astro';
import { SITE } from '@/config/site';
import { getReleaseSnapshot } from '@/lib/release';

const snapshot = await getReleaseSnapshot();
const releasedDate = new Date(snapshot.release.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<Layout
  title="Download DbPaw | Latest Release"
  description="Download the latest DbPaw release for macOS, Windows, and Linux."
  path="/download"
>
  <section class="hero">
    <span class="badge">Latest release {snapshot.release.version}</span>
    <h1>Download DbPaw</h1>
    <p>Recommended build for your platform is selected automatically. You can still choose manually below.</p>

    <div class="hero-actions">
      <a class="button primary" id="smart-download" href={snapshot.downloads.mac ?? snapshot.release.notesUrl}>
        Download for your platform
      </a>
      <a class="button ghost" href={snapshot.release.notesUrl} target="_blank" rel="noreferrer">
        Release Notes
      </a>
    </div>

    <p class="notice">Published on {releasedDate}. Source: {snapshot.source === 'github' ? 'GitHub API' : 'fallback config'}.</p>
  </section>

  <section>
    <h2 class="section-title">Manual downloads</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Platform</th>
          <th>Installer</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>macOS</td>
          <td><a href={snapshot.downloads.mac ?? snapshot.release.notesUrl}>Download</a></td>
        </tr>
        <tr>
          <td>Windows</td>
          <td><a href={snapshot.downloads.windows ?? snapshot.release.notesUrl}>Download</a></td>
        </tr>
        <tr>
          <td>Linux</td>
          <td><a href={snapshot.downloads.linux ?? snapshot.release.notesUrl}>Download</a></td>
        </tr>
      </tbody>
    </table>

    <div class="faq-item" style="margin-top: 20px;">
      <h3>macOS security warning fix</h3>
      <p>
        If macOS shows a quarantine warning, move <span class="inline-code">DbPaw.app</span> into
        <span class="inline-code">/Applications</span> and run:
      </p>
      <p style="margin-top:10px;">
        <span class="inline-code">sudo xattr -d com.apple.quarantine /Applications/DbPaw.app</span>
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ links: snapshot.downloads, fallback: snapshot.release.notesUrl }}>
    const button = document.getElementById('smart-download');
    if (button) {
      const ua = navigator.userAgent.toLowerCase();
      let platform = 'mac';

      if (ua.includes('win')) {
        platform = 'windows';
      } else if (ua.includes('linux')) {
        platform = 'linux';
      }

      const selected = links[platform] ?? fallback;
      button.href = selected;
      button.textContent = `Download for ${platform === 'mac' ? 'macOS' : platform === 'windows' ? 'Windows' : 'Linux'}`;
    }
  </script>
</Layout>
