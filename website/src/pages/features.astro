---
import Layout from '@/components/Layout.astro';
import { FEATURES } from '@/config/features';
---

<Layout
  title="DbPaw Features | AI-Powered SQL Workflow"
  description="Explore DbPaw features for SQL editing, data exploration, SSH connectivity, and AI assistance."
  path="/features"
>
  <section class="hero">
    <span class="badge">Capabilities</span>
    <h1>Built for modern database teams</h1>
    <p>
      DbPaw combines native performance and an intentional interface so your team can query, inspect,
      and optimize faster.
    </p>
  </section>

  <section>
    <div class="panel-grid">
      {
        FEATURES.map((feature) => (
          <article class="panel">
            <span class="badge">{feature.tag}</span>
            <h3>{feature.title}</h3>
            <p>{feature.summary}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
