---
import Layout from '@/components/Layout.astro';
import Cta from '@/components/landing/Cta.astro';
import Faq from '@/components/landing/Faq.astro';
import Features from '@/components/landing/Features.astro';
import Hero from '@/components/landing/Hero.astro';
import Logos from '@/components/landing/Logos.astro';
import Screenshots from '@/components/landing/Screenshots.astro';
import { SITE } from '@/config/site';
import { getReleaseSnapshot } from '@/lib/release';

const snapshot = await getReleaseSnapshot();
const releasedDate = new Date(snapshot.release.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<Layout title={SITE.title} description={SITE.description} path="/">
  <Hero
    version={snapshot.release.version}
    releasedDate={releasedDate}
    releaseNotesUrl={snapshot.release.notesUrl}
    source={snapshot.source}
    downloads={snapshot.downloads}
  />
  <Features />
  <Logos />
  <Screenshots />
  <Cta
    version={snapshot.release.version}
    releaseNotesUrl={snapshot.release.notesUrl}
    downloads={snapshot.downloads}
  />
  <Faq />
</Layout>
